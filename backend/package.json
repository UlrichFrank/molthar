{
  "name": "portale-von-molthar-backend",
  "version": "1.0.0",
  "description": "Backend server for Portale von Molthar multiplayer game",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server-bgio.ts",
    "build": "tsc",
    "start": "node dist/server-bgio.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@portale-von-molthar/shared": "workspace:*",
    "boardgame.io": "^0.50.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
